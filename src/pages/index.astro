---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const base = import.meta.env.BASE_URL;

// Define projects data
const featuredProject = {
  title: 'Eval-driven AI authoring system',
  description: 'An orchestrator-agent authoring system. The judge and fixer are separate, a three-part hard gate runs through a zero-dependency validator, and the judge is calibrated against a human gold set. Fluent-but-wrong content can\'t pass.',
  image: '/images/featured-hero.svg',
  href: '/projects/ai-authoring-system',
  tags: ['Agent orchestration', 'Evals', 'LLM-as-judge', 'CLAUDE.md']
};

const projects = [
  {
    title: 'Stripe billing, productionized',
    description: 'A stale customer ID silently double-charged a card $138, so I made a test-mode billing system safe to take real money: a 95-case test harness from zero, a self-healing webhook resilience layer, and the live migration.',
    image: '/images/stripe-billing-hero.svg',
    href: '/projects/stripe-billing-productionization',
    tags: ['Stripe', 'Payments', 'Webhooks', 'Idempotency'],
    categories: ['engineering']
  },
  {
    title: 'Voice-to-Prototype agentic pipeline',
    description: 'A GitHub-native agentic pipeline: a labelled issue triggers a constrained Claude Code run that opens a draft PR plus preview. The workflow owns git, not the model. Trust-gated and injection-hardened. I debugged it across a live 4-PR arc, then honestly held it behind a pivot.',
    image: '/images/voice-to-prototype-hero.svg',
    href: '/projects/voice-to-prototype-pipeline',
    tags: ['Agent development', 'GitHub Actions', 'Prompt-injection hygiene', 'Claude Code'],
    categories: ['ai-systems', 'engineering']
  },
  {
    title: 'Second Brain: LLM-maintained wiki',
    description: 'A compounding personal wiki where the LLM compiles knowledge once and keeps it current. It summarises, cross-references, and flags contradictions across 100 interlinked pages (0 hand-written) from 66 sources. A deliberate alternative to query-time RAG.',
    image: '/images/second-brain-hero.svg',
    href: '/projects/second-brain-knowledge-base',
    tags: ['Knowledge engineering', 'RAG alternative', 'CLAUDE.md', 'Obsidian'],
    categories: ['ai-systems', 'learning']
  },
  {
    title: 'Firestore security rules + emulator suite',
    description: 'Threat-modelled the economic attack surface of a SaaS data layer (no self-granting a paid tier, no inflating credits) and defended it with field allowlisting and diff-based update guards. Proven with 59 allow/deny cases against the shipped rules in the Firebase emulator.',
    image: '/images/firestore-security-hero.svg',
    href: '/projects/firestore-security-rules',
    tags: ['Firestore', 'Security', 'Emulator testing', 'Threat modeling'],
    categories: ['engineering']
  },
  {
    title: 'Natural-language control for Ableton Live',
    description: 'Integrated an open-source MCP bridge to drive a live Ableton session by voice or text. The real work wasn\'t building the bridge. It was a one-command idempotent install (7 steps to 1) and a log-driven diagnosis.',
    image: '/images/ableton-mcp-hero.svg',
    href: '/projects/ableton-mcp-control-layer',
    tags: ['MCP', 'Systems integration', 'macOS', 'Debugging'],
    categories: ['ai-systems', 'engineering']
  },
  {
    title: 'Content drift detection (agentic)',
    description: 'A three-skill agent pipeline (release-analyzer → content-mapper → change-generator) that detects which docs an API release impacts and drafts the updates. A human reviews them before they reach developers.',
    image: '/images/content-drift-hero.svg',
    href: '/projects/content-drift-detection-system',
    tags: ['Agent skills', 'Progressive disclosure', 'Drift detection', 'Human-in-the-loop'],
    categories: ['ai-systems', 'engineering']
  },
  {
    title: 'AI grading & evaluation system',
    description: 'An LLM evaluation system that scores submissions against a structured rubric, with quality gates that catch ungrounded or hallucinated judgments. It runs at a fraction of the cost and time of manual assessment.',
    image: '/images/paper-grader-hero.svg',
    href: '/projects/paper-grader',
    tags: ['Claude API', 'Evals', 'Quality gates', 'Python'],
    categories: ['ai-systems']
  },
  {
    title: 'Geocoding accuracy campaign',
    description: 'A diagnose-and-fix campaign on ~110K planning permits. I reframed a 5.8% per-run geocoding rate as a data-quality problem and wrote the address normalizer that recovered 47% of the failing backlog, lifting whole-dataset coverage to 98.3%.',
    image: '/images/geocoding-hero.svg',
    href: '/projects/geocoding-accuracy-campaign',
    tags: ['Data quality', 'Geocoding', 'Address normalization', 'Debugging'],
    categories: ['engineering']
  },
  {
    title: 'Single-source-of-truth docs program',
    description: 'A 5-person program that killed the cross-microsite duplication degrading search and RAG retrieval. One canonical source per concept, codified as a reusable 0-4 classification skill. ~2,660 lines consolidated across 8 domains, 1 microsite sunset.',
    image: '/images/dedup-hero.svg',
    href: '/projects/single-source-of-truth-docs-program',
    tags: ['Information architecture', 'RAG retrieval', 'Single source of truth'],
    categories: ['engineering', 'ai-systems']
  },
  {
    title: 'In-app bug-reporting pipeline',
    description: 'A five-stage serverless pipeline (scoped screenshot upload, private GitHub issue, HMAC-verified resolution webhook, two-pass retention GC) shipped to all users with distributed-systems hygiene and a ~1.3:1 test-to-source ratio.',
    image: '/images/bug-pipeline-hero.svg',
    href: '/projects/bug-reporting-pipeline',
    tags: ['Serverless', 'HMAC', 'Idempotency', 'PII handling'],
    categories: ['engineering']
  },
  {
    title: 'Distributed scraper CI orchestration',
    description: 'The CI orchestration that keeps a brittle ~40-job scraping fleet reliable: matrix failure isolation, an LFS-safe concurrent-commit loop that survives main moving mid-run, and an infra-vs-bug failure taxonomy with bounded auto-rerun.',
    image: '/images/scraper-ci-hero.svg',
    href: '/projects/scraper-ci-orchestration',
    tags: ['GitHub Actions', 'Git LFS', 'Reliability', 'CI/CD'],
    categories: ['engineering']
  },
  {
    title: 'Alex Chen: synthetic eval persona',
    description: 'A synthetic user that validates documentation by simulating a senior developer\'s feedback patterns. An evaluation persona for catching gaps before real developers hit them.',
    image: '/images/alex-chen-hero.svg',
    href: '/projects/alex-chen-learner-persona',
    tags: ['Synthetic users', 'Prompt engineering', 'Evals'],
    categories: ['ai-systems', 'learning']
  },
  {
    title: 'B2B Commerce learning path',
    description: 'Owned a B2B modeling path end to end. SME-validated, authored for the Functional Architect persona, with every API example verified against the RAML source. Module 2 passed the eval-driven critique gate at 88/100.',
    image: '/images/b2b-learning-hero.svg',
    href: '/projects/b2b-learning-path',
    tags: ['Curriculum architecture', 'SME synthesis', 'API-verified', 'Built & shipped'],
    categories: ['learning', 'engineering']
  },
  {
    title: 'Modular learning path ecosystem',
    description: 'Scalable content architecture supporting 9 paths, 30+ modules, and 200+ pages of technical material. One information architecture serving thousands of developers.',
    image: '/images/modular-paths-hero.svg',
    href: '/projects/modular-learning-paths',
    tags: ['Information architecture', 'Markdown', 'Git'],
    categories: ['learning']
  },
  {
    title: 'Developer Essentials learning path',
    description: 'A 20-hour curriculum that takes enterprise developers from zero to production-ready through hands-on, API-first mastery.',
    image: '/images/dev-essentials-hero.svg',
    href: '/projects/developer-essentials-learning-path',
    tags: ['Curriculum design', 'TypeScript', 'Java', 'API education'],
    categories: ['learning']
  },
  {
    title: 'Marcus Aurelius AI mentor',
    description: 'A conversational AI companion built on Socratic, persona-driven dialogue. An experiment in how far a single well-designed prompt system can carry an experience.',
    image: '/images/marcus-hero.svg',
    href: '/projects/marcus-aurelius',
    tags: ['Conversational AI', 'Prompt engineering', 'Next.js'],
    categories: ['ai-systems']
  },
  {
    title: '3 Steps Away: social-justice education platform',
    description: 'Co-founded an education enterprise teaching high schoolers to respond to complex social issues through visual storytelling and experiential learning. Where the systems thinking started.',
    image: '/images/3-steps-hero.svg',
    href: '/projects/3-steps-away',
    tags: ['Founder', 'Experiential learning', 'Youth education'],
    categories: ['learning']
  }
];

const categoryFilters = [
  { slug: 'all', label: 'All' },
  { slug: 'ai-systems', label: 'AI Systems & Agents' },
  { slug: 'engineering', label: 'Software Engineering' },
  { slug: 'learning', label: 'Learning Systems' }
];

const agenticToolchain = [
  'Subagents', 'Multi-agent orchestration', 'Dynamic workflows', 'Routines (scheduled agents)',
  'Loops', 'Eval harnesses', 'Plan mode', 'Agentic loops', 'Worktrees',
  'Headless / CLI in CI', 'MCP server development', 'Skills', 'CLAUDE.md schema design', 'CLI in VS Code'
];

const skills = {
  'Agentic engineering (Claude Code)': ['Subagents & multi-agent orchestration', 'Dynamic workflows', 'Eval harnesses', 'MCP server development', 'Headless / CLI in CI', 'CLAUDE.md schema design'],
  'AI Systems & Agents': ['Agent development & orchestration', 'Evals (LLM-as-judge, gold sets)', 'RAG & retrieval design', 'Prompt engineering', 'Claude API/SDK'],
  'Software Engineering': ['TypeScript / Node.js', 'Python', 'Firestore + security rules', 'Stripe integrations', 'CI/CD (GitHub Actions)', 'Webhooks · idempotency · HMAC'],
  'Learning Systems': ['Information architecture', 'Single-source-of-truth design', 'Curriculum architecture', 'SME synthesis'],
  'Tools & Platforms': ['Git / GitHub', 'Astro / MDX', 'Vercel', 'Obsidian', 'Algolia']
};
---

<Layout>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-bg-primary">
      <!-- Atmospheric background effects -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-accent-primary/15 rounded-full blur-[120px] animate-glow"></div>
        <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-accent-secondary/10 rounded-full blur-[100px]" style="animation: glow 10s ease-in-out infinite; animation-delay: 2s;"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-6 py-24 md:py-40">
        <div class="max-w-4xl stagger-children">
          <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-text-primary mb-8 leading-[1.1]">
            <span class="block">I build production AI systems</span>
            <span class="block text-accent-primary text-3xl md:text-5xl lg:text-6xl mt-2">and prove they work</span>
          </h1>

          <p class="text-xl md:text-2xl text-text-secondary mb-12 leading-relaxed max-w-3xl">
            Applied AI with an educator's edge. I design, ship, and validate real systems: agentic pipelines, payment integrity, AI authoring tools. Then I make them usable.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`${base}#work`}
              class="group inline-flex items-center justify-center px-8 py-4 bg-gradient-accent text-bg-primary rounded-lg font-bold hover:shadow-xl hover:shadow-accent-primary/30 transition-all duration-300 hover:-translate-y-1"
            >
              View my work
              <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </a>
            <a
              href={`${base}#contact`}
              class="inline-flex items-center justify-center px-8 py-4 border border-border-medium rounded-lg font-bold text-text-primary hover:border-accent-primary hover:bg-bg-elevated transition-all duration-300"
            >
              Get in touch
            </a>
          </div>
        </div>
      </div>
      
      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 -ml-3 flex items-center justify-center animate-bounce">
        <svg class="w-6 h-6 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </section>
    
    <!-- Featured Project -->
    <section class="relative py-24 md:py-40 bg-bg-primary overflow-hidden">
      <!-- Atmospheric background effects -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent-primary/10 rounded-full blur-[150px] animate-glow"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-secondary/5 rounded-full blur-[100px]" style="animation: glow 12s ease-in-out infinite; animation-delay: 3s;"></div>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-6">
        <!-- Header Badge with enhanced animation -->
        <div class="flex mb-8">
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-accent rounded-full opacity-75 blur-md group-hover:opacity-100 transition-opacity"></div>
            <div class="relative inline-flex items-center justify-center gap-2 px-6 py-3 bg-bg-elevated border-2 border-accent-primary/50 rounded-full text-sm font-bold text-accent-primary shadow-lg">
              <span class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-accent-primary"></span>
              </span>
              <span class="uppercase tracking-wider">Featured Project</span>
              <span class="w-2 h-2"></span>
            </div>
          </div>
        </div>
        
        <!-- Split Layout with Image on Right -->
        <div class="relative">
          <!-- Animated gradient border -->
          <div class="absolute -inset-1 bg-gradient-to-r from-accent-primary via-accent-secondary to-accent-primary rounded-3xl opacity-20 blur-xl animate-border-glow"></div>
          
          <div class="relative rounded-3xl border border-border-medium overflow-hidden shadow-2xl">
            <!-- Grid Container -->
            <div class="grid lg:grid-cols-2 gap-0 min-h-[600px] md:min-h-[700px] lg:min-h-[800px]">
              <!-- Content Column -->
              <div class="relative bg-gradient-to-br from-bg-secondary to-bg-elevated p-8 md:p-12 lg:p-16 flex items-center">
                <div class="w-full space-y-8">
                  <!-- Title with AI emphasis -->
                  <div>
                    <div class="inline-flex items-center gap-2 mb-4 px-4 py-2 bg-accent-primary/20 backdrop-blur-sm border border-accent-primary/40 rounded-full">
                      <svg class="w-5 h-5 text-accent-primary" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M13 7H7v6h6V7z"/>
                        <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1H9v1a1 1 0 11-2 0v-1H5a2 2 0 01-2-2v-2H2a1 1 0 110-2h1V9H2a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM5 5h10v10H5V5z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-sm font-bold text-accent-primary uppercase tracking-wider">Applied AI · Eval-driven</span>
                    </div>
                    
                    <h2 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-text-primary mb-4 leading-[1.05] tracking-tight">
                      <span class="block">Eval-driven</span>
                      <span class="block text-accent-primary">AI authoring</span>
                    </h2>

                    <p class="text-lg md:text-xl text-text-primary leading-relaxed max-w-xl bg-bg-primary/95 p-4 rounded-lg -ml-4">
                      Each authoring concern maps to the right primitive, with a hard gate that refuses to let an LLM grade its own work.
                    </p>
                  </div>
                  
                  <!-- Key Metrics with glass effect -->
                  <div class="flex flex-wrap gap-4">
                    <div class="backdrop-blur-md bg-bg-elevated/80 rounded-xl p-4 border border-border-medium hover:border-accent-primary/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-primary/20">
                      <div class="text-3xl font-bold text-accent-primary mb-1">0</div>
                      <div class="text-sm text-text-tertiary font-semibold">False-passes at threshold</div>
                    </div>
                    <div class="backdrop-blur-md bg-bg-elevated/80 rounded-xl p-4 border border-border-medium hover:border-accent-primary/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-primary/20">
                      <div class="text-3xl font-bold text-accent-primary mb-1">10</div>
                      <div class="text-sm text-text-tertiary font-semibold">Gold-set items (2 adversarial)</div>
                    </div>
                    <div class="backdrop-blur-md bg-bg-elevated/80 rounded-xl p-4 border border-border-medium hover:border-accent-primary/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-primary/20">
                      <div class="text-3xl font-bold text-accent-primary mb-1">18</div>
                      <div class="text-sm text-text-tertiary font-semibold">Prompts → agents &amp; skills</div>
                    </div>
                  </div>
                  
                  <!-- Tags with glass effect -->
                  <div class="flex flex-wrap gap-3">
                    {featuredProject.tags.map((tag, index) => (
                      <span 
                        class="inline-flex items-center px-4 py-2 bg-bg-primary/60 border border-accent-primary/40 text-accent-primary rounded-lg text-sm font-semibold hover:bg-bg-primary/80 hover:shadow-lg hover:shadow-accent-primary/20 transition-all duration-300 hover:-translate-y-0.5"
                        style={`animation: fadeInUp 0.6s ease-out forwards; animation-delay: ${0.8 + index * 0.1}s; opacity: 0;`}
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                  
                  <!-- CTA Button with enhanced styling -->
                  <div class="pt-2">
                    <a
                      href={featuredProject.href}
                      class="group/btn relative inline-flex items-center justify-center px-8 py-4 bg-gradient-accent text-bg-primary rounded-xl font-bold overflow-hidden hover:shadow-2xl hover:shadow-accent-primary/50 transition-all duration-300 hover:-translate-y-1 hover:scale-105"
                    >
                      <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-accent-secondary to-accent-primary opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></span>
                      <span class="relative flex items-center text-base md:text-lg">
                        Explore full case study
                        <svg class="w-5 h-5 ml-2 group-hover/btn:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                      </span>
                    </a>
                  </div>
                </div>
              </div>
              
              <!-- Visual Column -->
              <div class="relative overflow-hidden group bg-bg-secondary/30">
                <!-- Layered glow effects -->
                <div class="absolute -inset-4 bg-gradient-accent opacity-30 blur-3xl group-hover:opacity-40 transition-opacity duration-500"></div>
                
                <!-- GIF/Image -->
                <div class="relative h-full w-full flex items-center justify-center p-12">
                  <img
                    src={featuredProject.image}
                    alt={featuredProject.title}
                    class="w-full h-auto object-contain rounded-2xl shadow-2xl group-hover:scale-105 transition-transform duration-700 ease-out relative z-10"
                  />
                  
                  <!-- Floating decorative elements -->
                  <div class="absolute top-1/4 right-1/4 w-32 h-32 bg-accent-primary/20 rounded-full blur-3xl animate-float"></div>
                  <div class="absolute bottom-1/3 left-1/3 w-40 h-40 bg-accent-secondary/15 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Projects Grid -->
    <section id="work" class="py-24 md:py-32 bg-bg-primary">
      <div class="max-w-7xl mx-auto px-6">
        <div class="mb-10">
          <h2 class="text-4xl md:text-5xl font-display font-bold text-text-primary mb-4">Selected work</h2>
          <p class="text-xl text-text-secondary">Production AI systems, hardened software, and the systems thinking that connects them.</p>
        </div>

        <!-- Category filter -->
        <div class="flex flex-wrap gap-3 mb-12" role="group" aria-label="Filter projects by category">
          {categoryFilters.map((f) => (
            <button
              type="button"
              data-filter={f.slug}
              class={`px-5 py-2.5 rounded-lg text-sm font-bold border transition-all duration-300 ${f.slug === 'all' ? 'bg-gradient-accent text-bg-primary border-transparent' : 'text-text-secondary border-border-medium hover:border-accent-primary hover:text-accent-primary'}`}
            >
              {f.label}
            </button>
          ))}
        </div>

        <div id="projects-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>
    </section>

    <script>
      const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
      const cards = document.querySelectorAll<HTMLElement>('#projects-grid [data-categories]');

      function setActive(active: HTMLButtonElement) {
        buttons.forEach((b) => {
          const on = b === active;
          b.classList.toggle('bg-gradient-accent', on);
          b.classList.toggle('text-bg-primary', on);
          b.classList.toggle('border-transparent', on);
          b.classList.toggle('text-text-secondary', !on);
          b.classList.toggle('border-border-medium', !on);
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const filter = btn.getAttribute('data-filter');
          setActive(btn);
          cards.forEach((card) => {
            const cats = (card.getAttribute('data-categories') || '').split(' ').filter(Boolean);
            const show = filter === 'all' || cats.includes(filter as string);
            card.classList.toggle('hidden', !show);
          });
        });
      });
    </script>
    
    <!-- Skills Section -->
    <section class="py-24 md:py-32 bg-bg-secondary">
      <div class="max-w-7xl mx-auto px-6">
        <div class="mb-16">
          <h2 class="text-4xl md:text-5xl font-display font-bold text-text-primary mb-4">Skills &amp; expertise</h2>
          <p class="text-xl text-text-secondary">The stack I design, ship, and validate with.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {Object.entries(skills).map(([category, items]) => (
            <div class="bg-bg-elevated border border-border-subtle rounded-xl p-6 hover:border-accent-primary/30 transition-all duration-300 hover:-translate-y-1">
              <h3 class="font-bold text-accent-primary mb-4 text-sm uppercase tracking-wider">{category}</h3>
              <ul class="space-y-3">
                {items.map((skill) => (
                  <li class="text-text-secondary flex items-start text-sm">
                    <svg class="w-4 h-4 mr-2 mt-0.5 flex-shrink-0 text-accent-primary" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    {skill}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- How I Build - Agentic Toolchain -->
    <section class="py-24 md:py-32 bg-bg-primary">
      <div class="max-w-7xl mx-auto px-6">
        <div class="mb-10 max-w-3xl">
          <h2 class="text-4xl md:text-5xl font-display font-bold text-text-primary mb-4">How I build</h2>
          <p class="text-xl text-text-secondary">I don't just call models. I build with the full agentic toolchain. What sets the work apart is fluency <span class="text-accent-primary font-semibold">operating the stack</span>, not just the API.</p>
        </div>

        <div class="flex flex-wrap gap-3">
          {agenticToolchain.map((tool) => (
            <span class="inline-flex items-center px-4 py-2.5 bg-bg-elevated border border-border-medium rounded-lg text-sm font-semibold text-text-secondary hover:border-accent-primary hover:text-accent-primary hover:-translate-y-0.5 transition-all duration-300">
              {tool}
            </span>
          ))}
        </div>
