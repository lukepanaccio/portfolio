---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const timeline = [
  {
    year: '2025-Present',
    title: 'Engineer & Equity Partner',
    company: 'storipro (proptech), remote',
    description: 'Joined as a contract engineer and was offered equity for shipping the platform\'s production systems. That covered the Stripe billing integration, a hardened Firestore security model proven with an emulator test suite, an autonomous issue-to-PR pipeline, and the data pipelines behind permit ingestion.'
  },
  {
    year: '2022-Present',
    title: 'Senior Instructional Designer / Learning Systems Architect',
    company: 'commercetools, remote in Italy and Australia',
    description: 'Architected an orchestrator-agent AI authoring system with an eval harness, built agentic content-drift detection running in CI, and drove a single-source-of-truth documentation program across the platform. Did all of it while designing the learning systems that serve thousands of global developers. Led the team\'s adoption of the agentic toolchain.'
  },
  {
    year: '2022',
    title: 'Graduate Certificate in Educational Design',
    company: 'Monash University, Australia',
    description: 'Formal training in instructional design principles, learning theory, and evidence-based assessment strategies.'
  },
  {
    year: '2019-2022',
    title: 'Co-Founder & Learning Designer',
    company: '3 Steps Away, Australia',
    description: 'Built social justice education enterprise from concept to market delivery. Led end-to-end learning strategy, product development, and commercialization of blended learning experiences.'
  },
  {
    year: '2019-2021',
    title: 'Humanities Learning Area Leader & House Leader',
    company: 'Emmaus College, Australia',
    description: 'Managed team of 30+ educators overseeing 15 subject programs. Led strategic learning operations and provided senior leadership for cohort of 150 students.'
  },
  {
    year: '2014-2018',
    title: 'Online Interfaith Dialogue Facilitator',
    company: 'Generation Global, remote international',
    description: 'Facilitated 200+ international video dialogues. Designed dialogue experiences across complex cultural contexts while managing stakeholder relationships with ministers, NGO founders, and thought leaders.'
  },
  {
    year: '2011-2018',
    title: 'Social Justice Coordinator & Teacher',
    company: 'St Monica\'s College, Australia',
    description: 'Coordinated extracurricular program for 150+ students. Designed experiential learning units and implemented state curriculum across multiple year levels and disciplines.'
  },
  {
    year: '2007',
    title: 'Master of Arts (Arts and Sciences)',
    company: 'Universiteit Maastricht, the Netherlands',
    description: 'Focus on anthropology, international development policy, and contemporary world history.'
  },
  {
    year: '2003-2006',
    title: 'Bachelor of Arts (Humanities and Social Sciences)',
    company: 'Universiteit Maastricht, the Netherlands',
    description: 'Focus on history, philosophy, international politics and sociology.'
  }
];
---

<Layout title="About - Luke Panaccio">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-bg-primary">
      <!-- Atmospheric background effects -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-accent-primary/10 rounded-full blur-[120px] animate-glow"></div>
        <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] bg-accent-secondary/8 rounded-full blur-[100px]" style="animation: glow 10s ease-in-out infinite; animation-delay: 2s;"></div>
      </div>
      
      <div class="relative max-w-4xl mx-auto px-6 py-24 md:py-32">
        <div class="stagger-children">
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-text-primary mb-12 leading-[1.1]">
            About me
          </h1>
          <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <div class="flex-shrink-0">
              <img 
                src="/images/luke-bnw-headshot.webp" 
                alt="Luke Panaccio" 
                class="w-40 h-40 md:w-48 md:h-48 rounded-full object-cover border-4 border-accent-primary/20 shadow-xl"
              />
            </div>
            <div class="flex-1 text-center md:text-left">
              <p class="text-xl md:text-2xl text-text-secondary leading-relaxed">
                I build production AI systems, then make them usable. The edge is an unusual one. A teaching background means the systems actually get used.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Main Content -->
    <section class="py-20 md:py-24 bg-bg-secondary">
      <div class="max-w-4xl mx-auto px-6">
        <div class="space-y-12">
          <div class="space-y-6">
            <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">My journey</h2>
            
            <div class="space-y-6 text-lg text-text-secondary leading-relaxed">
              <p>
                Today I build production AI and software systems. As an engineer and equity partner at <span class="text-accent-primary font-semibold">storipro</span>, I shipped the platform's Stripe billing integration, threat-modelled and hardened its data-security layer, and built an autonomous issue-to-PR pipeline. At <span class="text-accent-primary font-semibold">commercetools</span>, I architected an orchestrator-agent AI authoring system with its own eval harness and drove a single-source-of-truth documentation program across the platform.
              </p>

              <p>
                I got here from an unusual direction. I came up through teaching, a decade of it, across three continents. I taught political philosophy at Universiteit Maastricht, English to Italian executives and at La Trobe University, then led a humanities department of 30+ educators in Australian secondary education. Co-founding <span class="text-accent-primary font-semibold">3 Steps Away</span>, a social-justice education enterprise, taught me to take a system from concept to market.
              </p>

              <p>
                That background is the edge, not the lane I'm leaving. Most builders can't communicate, and most communicators can't build. I spent years making complex ideas land for real people, so I design systems for the humans and agents that use them. That means clear interfaces, honest failure modes, and docs that actually double as a contract. I formalized the craft with a Graduate Certificate in Educational Design from Monash University. The engineering I formalized by shipping.
              </p>

              <p>
                Now I work at that intersection. Applied AI, built and validated, then made usable. That's the work Solutions Architect, Forward-Deployed Engineer, and founder-track roles are hired for.
              </p>
            </div>
          </div>
          
          <div class="space-y-6">
            <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">What I do</h2>
            
            <p class="text-lg text-text-secondary leading-relaxed">
              I work at the intersection of building and communicating. I architect and ship applied-AI systems, then make them legible to the people and models that use them. Here's where that splits.
            </p>

            <div class="grid md:grid-cols-2 gap-6 mt-8">
              <div class="bg-bg-elevated border border-border-subtle rounded-xl p-6 hover:border-accent-primary/30 transition-all duration-300 hover:-translate-y-1">
                <h3 class="font-bold text-accent-primary mb-3 text-base uppercase tracking-wider">AI Systems &amp; Agents</h3>
                <p class="text-text-secondary text-base leading-relaxed">
                  I design and ship agentic systems: orchestrator-agent architectures, RAG and retrieval, autonomous pipelines. I built an AI authoring system with its own eval harness, and an autonomous issue-to-PR pipeline running in production CI.
                </p>
              </div>
              <div class="bg-bg-elevated border border-border-subtle rounded-xl p-6 hover:border-accent-primary/30 transition-all duration-300 hover:-translate-y-1">
                <h3 class="font-bold text-accent-primary mb-3 text-base uppercase tracking-wider">Agentic Engineering (Claude Code)</h3>
                <p class="text-text-secondary text-base leading-relaxed">
                  I operate the full agentic toolchain: subagents, dynamic workflows, eval harnesses, MCP servers, headless Claude Code in CI, worktrees, CLAUDE.md schemas. I run the stack, I don't just call the API.
                </p>
              </div>
              <div class="bg-bg-elevated border border-border-subtle rounded-xl p-6 hover:border-accent-primary/30 transition-all duration-300 hover:-translate-y-1">
                <h3 class="font-bold text-accent-primary mb-3 text-base uppercase tracking-wider">Production Software Engineering</h3>
                <p class="text-text-secondary text-base leading-relaxed">
                  I ship hardened production code. A full Stripe billing integration with idempotency and self-healing reconciliation, a threat-modelled Firestore security layer proven with an emulator test suite, and distributed-systems hygiene throughout.
                </p>
              </div>
              <div class="bg-bg-elevated border border-border-subtle rounded-xl p-6 hover:border-accent-primary/30 transition-all duration-300 hover:-translate-y-1">
                <h3 class="font-bold text-accent-primary mb-3 text-base uppercase tracking-wider">Learning Systems (the edge)</h3>
                <p class="text-text-secondary text-base leading-relaxed">
                  A decade spent making complex ideas land. I bring information architecture, single-source-of-truth design, and curriculum thinking to the systems I build, so the agents and humans that depend on them can actually use them.
                </p>
              </div>
            </div>
          </div>
          
          <div class="space-y-6">
            <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">My philosophy</h2>
            
            <div class="space-y-6 text-lg text-text-secondary leading-relaxed">
              <p>
                I build for <strong>judgment, not output</strong>. Anyone can wire up an API call. The value is in the decisions: what to build, what to reject, and how you'll know it worked. Every system I ship leads with the architecture call and the trade-off behind it, backed by evals, quality gates, and honest failure handling.
              </p>

              <p>
                I treat <strong>documentation as data and interfaces as contracts</strong>. The hardest part of an AI system isn't the model. It's making the behaviour legible and the output trustworthy to the humans and agents downstream. That's where the teaching background compounds. I've spent years turning complexity into something people can act on.
              </p>

              <p>
                And I <strong>validate before I claim</strong>. A number I can defend in an interview beats a demo every time. The receipts carry the work.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Timeline -->
    <section class="py-20 md:py-24 bg-bg-primary">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary mb-12">Professional timeline</h2>
        
        <div class="space-y-8">
          {timeline.map((item, index) => (
            <div class="flex gap-6 animate-fade-in" style={`animation-delay: ${index * 0.1}s; opacity: 0;`}>
              <div class="flex-shrink-0 w-24 text-right">
                <span class="text-sm font-bold text-accent-primary">{item.year}</span>
              </div>
              <div class="flex-shrink-0">
                <div class="w-3 h-3 bg-accent-primary rounded-full mt-1.5 shadow-lg shadow-accent-primary/50"></div>
                <div class="w-0.5 h-full bg-border-medium mx-auto mt-1"></div>
              </div>
              <div class="flex-grow pb-8">
                <h3 class="font-bold text-text-primary mb-1 text-xl">{item.title}</h3>
                <p class="text-sm text-accent-secondary font-medium mb-2">{item.company}</p>
                <p class="text-text-secondary leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- CTA -->
    <section class="relative py-20 md:py-24 bg-bg-secondary overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent-primary/10 rounded-full blur-[120px]"></div>
      </div>
      
      <div class="relative max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary mb-6">Let's work together</h2>
        <p class="text-lg text-text-secondary mb-12 max-w-2xl leading-relaxed">
          I'm open to applied-AI, Solutions Architect, and Forward-Deployed Engineer roles, anywhere the job is to architect production AI systems and make them usable. If that's what you're building, I'd love to connect.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`${base}#contact`}
            class="group inline-flex items-center justify-center px-8 py-4 bg-gradient-accent text-bg-primary rounded-lg font-bold hover:shadow-xl hover:shadow-accent-primary/30 transition-all duration-300 hover:-translate-y-1"
          >
            Get in touch
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={`${base}#work`}
            class="inline-flex items-center justify-center px-8 py-4 border border-border-medium rounded-lg font-bold text-text-primary hover:border-accent-primary hover:bg-bg-elevated transition-all duration-300"
          >
          View my work
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* Custom utilities using CSS variables */
  .bg-bg-primary {
    background-color: var(--color-bg-primary);
  }
  
  .bg-bg-secondary {
    background-color: var(--color-bg-secondary);
  }
  
  .bg-bg-elevated {
    background-color: var(--color-bg-elevated);
  }
  
  .bg-gradient-accent {
    background: var(--gradient-accent);
  }
  
  .text-text-primary {
    color: var(--color-text-primary);
  }
  
  .text-text-secondary {
    color: var(--color-text-secondary);
  }
  
  .text-accent-primary {
    color: var(--color-accent-primary);
  }
  
  .text-accent-secondary {
    color: var(--color-accent-secondary);
  }
  
  .text-bg-primary {
    color: var(--color-bg-primary);
  }
  
  .border-border-subtle {
    border-color: var(--color-border-subtle);
  }
  
  .border-border-medium {
    border-color: var(--color-border-medium);
  }
  
  .border-accent-primary {
    border-color: var(--color-accent-primary);
  }
  
  /* Animation for glow effect */
  @keyframes glow {
    0%, 100% {
      opacity: 0.1;
    }
    50% {
      opacity: 0.2;
    }
  }
  
  .animate-glow {
    animation: glow 8s ease-in-out infinite;
  }
</style>